# General
APP_VERSION=dev
TZ=Asia/Bangkok
SPRING_PROFILES_ACTIVE=dev

# Docker logging
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# PostgreSQL
POSTGRES_HOST_PORT=5432
POSTGRES_USER=lifebalance_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lifebalance

KEYCLOAK_DB=lifebalance_keycloak
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=change-me

IDENTITY_DB=lifebalance_identity
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=change-me

TASK_DB=lifebalance_task
TASK_DB_USER=task_user
TASK_DB_PASSWORD=change-me

TIMELINE_DB=lifebalance_timeline
TIMELINE_DB_USER=timeline_user
TIMELINE_DB_PASSWORD=change-me

FINANCE_DB=lifebalance_finance
FINANCE_DB_USER=finance_user
FINANCE_DB_PASSWORD=change-me

NOTIFICATION_DB=lifebalance_notification
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=change-me

ANALYTICS_DB=lifebalance_analytics
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=change-me

AI_DB=lifebalance_ai
AI_DB_USER=ai_user
AI_DB_PASSWORD=change-me

# Keycloak
KEYCLOAK_HOST_PORT=8082
KEYCLOAK_MGMT_HOST_PORT=9000
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=lifebalance
KEYCLOAK_FRONTEND_CLIENT_ID=lifebalance-web
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/lifebalance
KEYCLOAK_ISSUER_URI_INTERNAL=http://keycloak:8080/realms/lifebalance

# Gateway and service ports
GATEWAY_HOST_PORT=8080
GATEWAY_PORT=8080
DISCOVERY_HOST_PORT=8761
DISCOVERY_PORT=8761
IDENTITY_SERVICE_PORT=8080
IDENTITY_DEBUG_HOST_PORT=8091
TASK_SERVICE_PORT=8080
TASK_DEBUG_HOST_PORT=8092
TIMELINE_SERVICE_PORT=8080
TIMELINE_DEBUG_HOST_PORT=8096
FINANCE_SERVICE_PORT=8080
FINANCE_DEBUG_HOST_PORT=8093
NOTIFICATION_SERVICE_PORT=8080
NOTIFICATION_DEBUG_HOST_PORT=8094
ANALYTICS_SERVICE_PORT=8080
ANALYTICS_DEBUG_HOST_PORT=8097
AI_SERVICE_PORT=8080
AI_DEBUG_HOST_PORT=8095

# Service discovery
EUREKA_DEFAULT_ZONE=http://discovery-server:8761/eureka
EUREKA_EVICTION_INTERVAL_MS=60000

# JWT
JWT_ISSUER_URI=http://keycloak:8080/realms/lifebalance
JWT_AUDIENCE=lifebalance-api

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@lifebalance.local

# RabbitMQ
RABBITMQ_AMQP_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
RABBITMQ_USER=lifebalance
RABBITMQ_PASSWORD=change-me

# Redis
REDIS_HOST_PORT=6379
REDIS_PASSWORD=change-me

# MinIO
MINIO_API_HOST_PORT=9002
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=lifebalance
MINIO_ROOT_PASSWORD=change-me-change-me

# Monitoring
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
